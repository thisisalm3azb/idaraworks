# IdaraWorks environment variables (S0 checklist §10).
# Copy to .env.local for development. NEVER commit real values.
# Each var: owner = who provisions it; phase = when it becomes required.

# ── App (Phase A) ────────────────────────────────────────────────────────────
APP_ENV=dev                      # dev | preview | prod
# LOG_LEVEL=debug

# ── Supabase (Phase B — required for db:migrate / vc1 / test:integration) ────
NEXT_PUBLIC_SUPABASE_URL=        # Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_ANON_KEY=   # auth only — data goes through the tenancy layer
DATABASE_URL=                    # "Transaction pooler" URI (port 6543). You may omit/redact the
                                 # password — the app NEVER uses it (env.ts swaps in app_user +
                                 # APP_DB_PASSWORD; keep privileged creds out of runtime env stores)
DIRECT_URL=                      # "Direct connection" URI (port 5432) — migrations/seeding only.
                                 # NOTE: db.<ref>.supabase.co is IPv6-only; on an IPv4-only network
                                 # use the SESSION-pooler URI (port 5432 on the pooler host) here
APP_DB_PASSWORD=                 # you generate this; runner sets it on the app_user role.
                                 # The app derives its pooled connection from DATABASE_URL
                                 # with app_user + this password (src/platform/tenancy/env.ts)
# APP_DB_POOL_MAX=10
# SUPABASE_SERVICE_ROLE_KEY=     # tooling/tests/CI ONLY — never app runtime (phase2/10 #1).
                                 # Phase E: needed locally for setup-storage.ts + integration tests

# ── Storage (Phase E — files & derivatives) ──────────────────────────────────
# STORAGE_S3_ACCESS_KEY_ID=      # Dashboard → Project Settings → Storage → S3 access keys.
# STORAGE_S3_SECRET_ACCESS_KEY=  # Storage-scoped worker credential (BUILD_BIBLE §5.2 platform
                                 # task) — CANNOT touch the database. Goes to Vercel + CI too.
# STORAGE_S3_ENDPOINT=           # optional; default <SUPABASE_URL>/storage/v1/s3
# STORAGE_S3_REGION=             # optional; default ap-northeast-2 (local stack: "local")

# ── Queue / events (Phase E client; outbox lands Phase G) ────────────────────
# INNGEST_EVENT_KEY=             # required before production pilots; dev mode without it
# INNGEST_SIGNING_KEY=           # required before production pilots (serve-route signature)

# ── Email / SMS (Phase C) ────────────────────────────────────────────────────
# RESEND_API_KEY=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_VERIFY_SID=

# ── Rate limiting (Phase C) ──────────────────────────────────────────────────
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ── Observability (Phase I) ──────────────────────────────────────────────────
# SENTRY_DSN=
# SENTRY_AUTH_TOKEN=              # CI only (sourcemaps)

# ── Crypto (Phase B+) ────────────────────────────────────────────────────────
# FIELD_ENCRYPTION_KEY=           # 32 bytes, base64 — future integration credentials
